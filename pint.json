{
    "preset": "laravel",
    "rules": {
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "trailing_comma_in_multiline": {
            "elements": [
                "arrays",
                "arguments",
                "parameters",
                "match",
                "array_destructuring"
            ]
        },
        "concat_space": {
            "spacing": "one"
        },
        "array_indentation": true,
        "binary_operator_spaces": true,
        "blank_line_before_statement": {
            "statements": [
                "return",
                "throw",
                "try"
            ]
        }
    }
}